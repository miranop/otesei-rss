---
interface Props {
  title?: string;
}
const { title = "RSS Reader" } = Astro.props;
---

<!doctype html>
<html lang="ja" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-surface-0 text-gray-100 font-sans min-h-screen">
    <header
      class="border-b border-border sticky top-0 z-50 bg-surface-0/95 backdrop-blur"
    >
      <div
        class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between"
      >
        <a
          href="/"
          class="font-mono text-accent font-medium tracking-tight text-sm flex items-center gap-2"
        >
          <span class="text-lg">⬡</span> rss.reader
        </a>
        <nav class="flex items-center gap-1">
          <a
            href="/"
            class="px-3 py-1.5 rounded text-sm text-muted hover:text-gray-100 hover:bg-surface-2 transition-colors"
          >
            フィード
          </a>
          <a
            href="/admin"
            class="px-3 py-1.5 rounded text-sm text-muted hover:text-gray-100 hover:bg-surface-2 transition-colors"
          >
            管理
          </a>
        </nav>
      </div>
    </header>
    <main class="max-w-6xl mx-auto px-4 py-8">
      <slot />
    </main>
  </body>
</html>
