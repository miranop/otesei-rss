---
import Base from "../layouts/Base.astro";
import {
  getArticles,
  getCategories,
  getFeeds,
  upsertArticles,
  getDb,
} from "../lib/db.ts";
import { fetchFeed } from "../lib/rss.ts";

const feeds = getFeeds();
await Promise.allSettled(
  feeds.map(async (feed) => {
    try {
      const { title, articles } = await fetchFeed(feed.url);
      if (!feed.title && title) {
        getDb()
          .prepare("UPDATE feeds SET title = ? WHERE id = ?")
          .run(title, feed.id);
      }
      upsertArticles(feed.id, articles);
    } catch (_) {
      // 個々のフィードエラーは無視
    }
  }),
);

const url = Astro.url;
const search = url.searchParams.get("q") ?? "";
const categoryId = url.searchParams.get("cat")
  ? Number(url.searchParams.get("cat"))
  : undefined;
const feedId = url.searchParams.get("feed")
  ? Number(url.searchParams.get("feed"))
  : undefined;

const categories = getCategories();
const articles = getArticles({ search, categoryId, feedId, limit: 200 });
---

<Base title="RSS Reader">
  <div class="flex flex-col sm:flex-row gap-3 mb-8">
    <form method="get" class="flex gap-2 flex-1">
      <input
        type="text"
        name="q"
        value={search}
        placeholder="記事を検索..."
        class="flex-1 bg-surface-2 border border-border rounded px-3 py-2 text-sm text-gray-100 placeholder-muted focus:outline-none focus:border-accent transition-colors"
      />
      {categoryId && <input type="hidden" name="cat" value={categoryId} />}
      {feedId && <input type="hidden" name="feed" value={feedId} />}
      <button
        type="submit"
        class="px-4 py-2 bg-accent text-surface-0 rounded text-sm font-medium hover:bg-accent/90 transition-colors"
      >
        検索
      </button>
    </form>
  </div>

  <div class="flex gap-6">
    <aside class="hidden lg:block w-52 shrink-0">
      <p class="text-xs font-mono text-muted uppercase tracking-widest mb-3">
        カテゴリ
      </p>
      <ul class="space-y-1">
        <li>
          <a
            href="/"
            class={`block px-3 py-1.5 rounded text-sm transition-colors ${!categoryId && !feedId ? "bg-surface-2 text-gray-100" : "text-muted hover:text-gray-100 hover:bg-surface-2"}`}
          >
            すべて
          </a>
        </li>
        {
          categories.map((cat) => (
            <li>
              href={`/?cat=${cat.id}`}
              class=
              {`flex items-center gap-2 px-3 py-1.5 rounded text-sm transition-colors ${categoryId === cat.id ? "bg-surface-2 text-gray-100" : "text-muted hover:text-gray-100 hover:bg-surface-2"}`}
              <a>
                <span
                  class="w-2 h-2 rounded-full shrink-0"
                  style={`background:${cat.color}`}
                />
                {cat.name}
              </a>
            </li>
          ))
        }
      </ul>

      <p
        class="text-xs font-mono text-muted uppercase tracking-widest mt-6 mb-3"
      >
        フィード
      </p>
      <ul class="space-y-1">
        {
          feeds.map((feed) => (
            <li>
              href={`/?feed=${feed.id}`}
              class=
              {`block px-3 py-1.5 rounded text-sm truncate transition-colors ${feedId === feed.id ? "bg-surface-2 text-gray-100" : "text-muted hover:text-gray-100 hover:bg-surface-2"}`}
              title={feed.title || feed.url}
              <a>{feed.title || feed.url}</a>
            </li>
          ))
        }
      </ul>
    </aside>

    <div class="flex-1 min-w-0">
      {
        articles.length === 0 ? (
          <div class="text-center py-24 text-muted">
            <p class="text-4xl mb-4">📭</p>
            <p class="text-sm">
              {feeds.length === 0
                ? "管理画面からフィードを追加してください"
                : "記事が見つかりませんでした"}
            </p>
          </div>
        ) : (
          <ul class="space-y-px">
            {articles.map((article) => (
              <li class="group border border-transparent hover:border-border hover:bg-surface-1 rounded-lg transition-colors">
                <a
                  href={article.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block px-4 py-3"
                >
                  <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                      <h2 class="text-sm font-medium text-gray-100 leading-snug line-clamp-2 group-hover:text-accent transition-colors">
                        {article.title}
                      </h2>
                      {article.summary && (
                        <p class="text-xs text-muted mt-1 line-clamp-2 leading-relaxed">
                          {article.summary}
                        </p>
                      )}
                      <div class="flex items-center gap-3 mt-2">
                        <span class="text-xs text-muted/70 font-mono">
                          {article.feed_title}
                        </span>
                        {article.category_name && (
                          <span
                            class="text-xs px-2 py-0.5 rounded-full font-mono"
                            style={`background:${article.category_color}22; color:${article.category_color}`}
                          >
                            {article.category_name}
                          </span>
                        )}
                        {article.author && (
                          <span class="text-xs text-muted/70">
                            {article.author}
                          </span>
                        )}
                      </div>
                    </div>
                    <time class="text-xs text-muted/60 font-mono whitespace-nowrap shrink-0 mt-0.5">
                      {article.pub_date
                        ? new Date(article.pub_date).toLocaleDateString(
                            "ja-JP",
                            { month: "short", day: "numeric" },
                          )
                        : ""}
                    </time>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</Base>
